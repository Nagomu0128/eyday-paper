# Copy to .dev.vars (gitignored) for local `vite dev` / `wrangler dev`.
# Production values are set via `wrangler secret put`. These are MOCKS — the
# Google OAuth client must be created by hand in the Google console (redirect
# URI https://eyday-paper.yoshidakazuya.com/api/auth/callback/google).
BETTER_AUTH_SECRET="dev-only-insecure-secret-change-me-0123456789"
BETTER_AUTH_URL="http://localhost:5173"
GOOGLE_CLIENT_ID="mock-google-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="mock-google-client-secret"
# AI Gateway routing + provider keys (LLM calls route through the gateway).
CF_ACCOUNT_ID="mock-cloudflare-account-id"
AI_GATEWAY_NAME="eyday-paper"
GEMINI_API_KEY="mock-gemini-api-key"
OPENAI_API_KEY="mock-openai-api-key"
